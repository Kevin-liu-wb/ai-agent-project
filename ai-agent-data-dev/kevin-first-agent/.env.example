# ===================== 数据库配置 =====================
POSTGRES_HOST=ai-agent-postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=job_agent

# ===================== Redis 配置 =====================
REDIS_HOST=ai-agent-redis
REDIS_PORT=6379
REDIS_DB=0

# ===================== OpenAI 配置 =====================
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# ===================== 可选：代理配置 =====================
HTTP_PROXY=
HTTPS_PROXY=

# ===================== 可选：LangSmith 监控 =====================
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=kevin-job-agent
